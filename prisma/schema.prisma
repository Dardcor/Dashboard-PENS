// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  dosen_wali
  mahasiswa
}

enum StatusAkademik {
  aktif
  cuti
  mengundurkan_diri
  drop_out
  lulus
}

enum TipeSemester {
  ganjil
  genap
}

enum JenisMatkul {
  wajib
  pilihan
  praktikum
}

enum GradeNilai {
  A
  AB
  B
  BC
  C
  D
  E
}

enum TipeAlert {
  nilai_rendah
  kehadiran_buruk
  ipk_turun
  sks_tidak_cukup
  belum_konsultasi
}

enum StatusAlert {
  aktif
  diproses
  selesai
  diabaikan
}

enum StatusNotif {
  belum_dibaca
  sudah_dibaca
}

enum TipeNotif {
  alert
  pengingat
  info
  jadwal
}

enum StatusCatatan {
  draft
  final
}

enum StatusJadwal {
  menunggu
  dikonfirmasi
  selesai
  dibatalkan
}

model User {
  id         String   @id @db.Uuid
  email      String   @unique
  full_name  String
  avatar_url String?
  role       UserRole @default(mahasiswa)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  mahasiswa           Mahasiswa?         @relation("UserToMahasiswa")
  dosen_wali          DosenWali?         @relation("UserToDosenWali")
  resolved_alerts     AlertAkademik[]    @relation("AlertResolvedBy")
  notifikasi          Notifikasi[]       @relation("NotifUser")
  jadwal_dibuat       JadwalKonsultasi[] @relation("JadwalDibuatOleh")
  konfigurasi_updated KonfigurasiAlert[] @relation("KonfigurasiUpdatedBy")
  ethol_session       UserEtholSession?

  @@map("users")
}

model DosenWali {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id        String   @unique @db.Uuid
  nip            String   @unique
  nama_lengkap   String
  gelar_depan    String?
  gelar_belakang String?
  prodi          String
  jurusan        String   @default("Teknik Informatika")
  no_hp          String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  user              User               @relation("UserToDosenWali", fields: [user_id], references: [id], onDelete: Cascade)
  mahasiswa_binaan  Mahasiswa[]        @relation("DosenWaliToMahasiswa")
  catatan_perwalian CatatanPerwalian[] @relation("CatatanDosenWali")
  jadwal_konsultasi JadwalKonsultasi[] @relation("JadwalDosenWali")

  @@map("dosen_wali")
}

model Mahasiswa {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id         String         @unique @db.Uuid
  dosen_wali_id   String?        @db.Uuid
  nrp             String         @unique
  nama_lengkap    String
  kelas           String
  prodi           String
  jurusan         String         @default("Teknik Informatika")
  angkatan        Int
  status_akademik StatusAkademik @default(aktif)
  no_hp           String?
  alamat          String?
  tanggal_lahir   DateTime?      @db.Date
  tempat_lahir    String?
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  user              User               @relation("UserToMahasiswa", fields: [user_id], references: [id], onDelete: Cascade)
  dosen_wali        DosenWali?         @relation("DosenWaliToMahasiswa", fields: [dosen_wali_id], references: [id], onDelete: SetNull)
  nilai             NilaiMahasiswa[]
  kehadiran         Kehadiran[]
  ipk_history       IpkHistory[]
  catatan_perwalian CatatanPerwalian[] @relation("CatatanMahasiswa")
  alert_akademik    AlertAkademik[]    @relation("AlertMahasiswa")
  notifikasi        Notifikasi[]       @relation("NotifMahasiswa")
  jadwal_konsultasi JadwalKonsultasi[] @relation("JadwalMahasiswa")
  tugas             Tugas[]

  @@map("mahasiswa")
}

model Semester {
  id              String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  kode            String       @unique
  nama            String
  tahun_akademik  String
  tipe            TipeSemester
  tanggal_mulai   DateTime     @db.Date
  tanggal_selesai DateTime     @db.Date
  is_aktif        Boolean      @default(false)
  created_at      DateTime     @default(now()) @db.Timestamptz(6)

  // Relations
  nilai             NilaiMahasiswa[]
  kehadiran         Kehadiran[]
  ipk_history       IpkHistory[]
  catatan_perwalian CatatanPerwalian[]
  alert_akademik    AlertAkademik[]
  jadwal_konsultasi JadwalKonsultasi[]

  @@map("semester")
}

model MataKuliah {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  kode            String
  nama            String
  sks             Int
  prodi           String
  jurusan         String      @default("Teknik Informatika")
  jenis           JenisMatkul @default(wajib)
  dosen           String?     @default("Dosen Pengampu")
  hari            String?     @default("Sesuai Jadwal")
  jam             String?     @default("Sesuai Jadwal")
  ruang           String?     @default("Kelas Virtual / Offline")
  deskripsi       String?
  ethol_course_id String?     @unique
  created_at      DateTime    @default(now()) @db.Timestamptz(6)
  updated_at      DateTime    @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  nilai     NilaiMahasiswa[]
  kehadiran Kehadiran[]
  tugas     Tugas[]
  materi    Materi[]

  @@map("mata_kuliah")
}

model NilaiMahasiswa {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  mahasiswa_id   String      @db.Uuid
  semester_id    String      @db.Uuid
  mata_kuliah_id String      @db.Uuid
  nilai_tugas    Float?
  nilai_uts      Float?
  nilai_uas      Float?
  nilai_akhir    Float?
  grade          GradeNilai?
  bobot_nilai    Float?
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  updated_at     DateTime    @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  mahasiswa   Mahasiswa  @relation(fields: [mahasiswa_id], references: [id], onDelete: Cascade)
  semester    Semester   @relation(fields: [semester_id], references: [id], onDelete: Restrict)
  mata_kuliah MataKuliah @relation(fields: [mata_kuliah_id], references: [id], onDelete: Cascade)

  @@unique([mahasiswa_id, semester_id, mata_kuliah_id])
  @@map("nilai_mahasiswa")
}

model Kehadiran {
  id                   String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  mahasiswa_id         String   @db.Uuid
  semester_id          String   @db.Uuid
  mata_kuliah_id       String   @db.Uuid
  total_pertemuan      Int      @default(0)
  hadir                Int      @default(0)
  izin                 Int      @default(0)
  sakit                Int      @default(0)
  alpha                Int      @default(0)
  persentase_kehadiran Float?
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  mahasiswa   Mahasiswa  @relation(fields: [mahasiswa_id], references: [id], onDelete: Cascade)
  semester    Semester   @relation(fields: [semester_id], references: [id], onDelete: Restrict)
  mata_kuliah MataKuliah @relation(fields: [mata_kuliah_id], references: [id], onDelete: Cascade)

  @@unique([mahasiswa_id, semester_id, mata_kuliah_id])
  @@map("kehadiran")
}

model IpkHistory {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  mahasiswa_id  String   @db.Uuid
  semester_id   String   @db.Uuid
  ips           Float
  ipk_kumulatif Float
  sks_semester  Int
  sks_kumulatif Int
  sks_lulus     Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  mahasiswa Mahasiswa @relation(fields: [mahasiswa_id], references: [id], onDelete: Cascade)
  semester  Semester  @relation(fields: [semester_id], references: [id], onDelete: Restrict)

  @@unique([mahasiswa_id, semester_id])
  @@map("ipk_history")
}

model CatatanPerwalian {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  mahasiswa_id  String        @db.Uuid
  dosen_wali_id String        @db.Uuid
  semester_id   String        @db.Uuid
  judul         String
  isi_catatan   String
  tindak_lanjut String?
  status        StatusCatatan @default(draft)
  tanggal       DateTime      @default(now()) @db.Date
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime      @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  mahasiswa  Mahasiswa @relation("CatatanMahasiswa", fields: [mahasiswa_id], references: [id], onDelete: Cascade)
  dosen_wali DosenWali @relation("CatatanDosenWali", fields: [dosen_wali_id], references: [id], onDelete: Restrict)
  semester   Semester  @relation(fields: [semester_id], references: [id], onDelete: Restrict)

  @@map("catatan_perwalian")
}

model AlertAkademik {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  mahasiswa_id    String      @db.Uuid
  semester_id     String      @db.Uuid
  tipe_alert      TipeAlert
  deskripsi       String
  status          StatusAlert @default(aktif)
  threshold_value Float?
  actual_value    Float?
  created_at      DateTime    @default(now()) @db.Timestamptz(6)
  resolved_at     DateTime?   @db.Timestamptz(6)
  resolved_by     String?     @db.Uuid

  // Relations
  mahasiswa  Mahasiswa    @relation("AlertMahasiswa", fields: [mahasiswa_id], references: [id], onDelete: Cascade)
  semester   Semester     @relation(fields: [semester_id], references: [id], onDelete: Restrict)
  resolver   User?        @relation("AlertResolvedBy", fields: [resolved_by], references: [id], onDelete: SetNull)
  notifikasi Notifikasi[] @relation("NotifAlert")

  @@map("alert_akademik")
}

model Notifikasi {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String      @db.Uuid
  mahasiswa_id String?     @db.Uuid
  alert_id     String?     @db.Uuid
  judul        String
  pesan        String
  tipe         TipeNotif   @default(info)
  status       StatusNotif @default(belum_dibaca)
  link_target  String?
  created_at   DateTime    @default(now()) @db.Timestamptz(6)
  dibaca_at    DateTime?   @db.Timestamptz(6)

  // Relations
  user      User           @relation("NotifUser", fields: [user_id], references: [id], onDelete: Cascade)
  mahasiswa Mahasiswa?     @relation("NotifMahasiswa", fields: [mahasiswa_id], references: [id], onDelete: Cascade)
  alert     AlertAkademik? @relation("NotifAlert", fields: [alert_id], references: [id], onDelete: SetNull)

  @@map("notifikasi")
}

model JadwalKonsultasi {
  id            String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  mahasiswa_id  String       @db.Uuid
  dosen_wali_id String       @db.Uuid
  semester_id   String?      @db.Uuid
  waktu_mulai   DateTime     @db.Timestamptz(6)
  waktu_selesai DateTime     @db.Timestamptz(6)
  status        StatusJadwal @default(menunggu)
  catatan       String?
  lokasi        String?
  dibuat_oleh   String       @db.Uuid
  created_at    DateTime     @default(now()) @db.Timestamptz(6)
  updated_at    DateTime     @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  mahasiswa  Mahasiswa @relation("JadwalMahasiswa", fields: [mahasiswa_id], references: [id], onDelete: Cascade)
  dosen_wali DosenWali @relation("JadwalDosenWali", fields: [dosen_wali_id], references: [id], onDelete: Restrict)
  semester   Semester? @relation(fields: [semester_id], references: [id], onDelete: SetNull)
  creator    User      @relation("JadwalDibuatOleh", fields: [dibuat_oleh], references: [id], onDelete: Restrict)

  @@map("jadwal_konsultasi")
}

model KonfigurasiAlert {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tipe_alert      TipeAlert @unique
  nama            String
  deskripsi       String?
  threshold_value Float
  is_aktif        Boolean   @default(true)
  updated_by      String?   @db.Uuid
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  updater User? @relation("KonfigurasiUpdatedBy", fields: [updated_by], references: [id], onDelete: SetNull)

  @@map("konfigurasi_alert")
}

model UserEtholSession {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String    @unique @db.Uuid
  ethol_cookie String
  last_sync_at DateTime? @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_ethol_sessions")
}

model Tugas {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  mahasiswa_id   String    @db.Uuid
  mata_kuliah_id String?   @db.Uuid
  judul          String
  deskripsi      String?
  deadline       DateTime? @db.Timestamptz(6)
  status         String    @default("Belum mengumpulkan")
  sumber_ethol   String?
  ethol_tugas_id Int?      @unique
  color          String?
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  mahasiswa   Mahasiswa   @relation(fields: [mahasiswa_id], references: [id], onDelete: Cascade)
  mata_kuliah MataKuliah? @relation(fields: [mata_kuliah_id], references: [id], onDelete: Cascade)

  @@map("tugas")
}

model Pengumuman {
  id                  String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  judul               String
  publisher           String
  tanggal             DateTime @db.Date
  isi                 String?
  file_url            String?
  file_name           String?
  sumber_url          String?
  ethol_pengumuman_id Int?     @unique
  created_at          DateTime @default(now()) @db.Timestamptz(6)

  @@map("pengumuman")
}

model Materi {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  mata_kuliah_id  String    @db.Uuid
  judul           String
  deskripsi       String?
  file_url        String?
  file_name       String?
  tanggal         DateTime? @db.Date
  ethol_materi_id Int?      @unique
  created_at      DateTime  @default(now()) @db.Timestamptz(6)

  // Relations
  mata_kuliah MataKuliah @relation(fields: [mata_kuliah_id], references: [id], onDelete: Cascade)

  @@map("materi")
}
